# Supabase Configuration - EXAMPLE
# ================================
# Copy this file to .env and fill in your actual values from Supabase
# The .env file is in .gitignore and should NEVER be committed to version control

# Your Supabase Project URL
# Get this from: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://your_project.supabase.co

# Your Supabase Anonymous Public Key (NOT the service key!)
# Get this from: Supabase Dashboard > Settings > API > Project API keys > anon (public key)
VITE_SUPABASE_ANON_KEY=your_supabase_public_anon_key_here
