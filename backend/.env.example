# ============================================
# WhatsApp Communication API - Environment Variables
# ============================================

# NODE.js Environment
NODE_ENV=development
PORT=5000

# ============================================
# WhatsApp API Configuration (REQUIRED)
# ============================================

# WhatsApp Business Phone Number ID
# Get from: https://developers.facebook.com/docs/whatsapp
# Steps:
# 1. Create Meta app on developers.facebook.com
# 2. Add WhatsApp product to your app
# 3. Get your Phone Number ID from Business Settings
PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Business Account API Token
# Get from: https://www.whatsapp.com/business/downloads/
# Must have these permissions:
# - whatsapp_business_messaging
# - whatsapp_business_management
WHATSAPP_TOKEN=your_access_token_here

# WhatsApp Graph API URL
# Latest version (leave as is)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ============================================
# Webhook Configuration (Optional)
# For receiving incoming messages
# ============================================
WEBHOOK_VERIFY_TOKEN=your_webhook_token_here

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# Database (Optional - if using logging)
# ============================================
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_key

# ============================================
# How to get WhatsApp Credentials:
# ============================================
# 1. Go to https://www.whatsapp.com/business/downloads/
# 2. Create a Meta Business Account (if you don't have one)
# 3. Set up WhatsApp Business Account
# 4. Create a Meta App at https://developers.facebook.com
# 5. Add WhatsApp as a product
# 6. Go to WhatsApp > API Setup
# 7. Copy Your Phone Number ID
# 8. Generate Temporary Access Token (or create permanent token)
# 9. Verify your phone number
# 10. Add test numbers (or use your actual number)
# 11. Paste values in this .env file

# ============================================
# Testing endpoints:
# ============================================
# Health check: GET http://localhost:5000/api/health
# Send message: POST http://localhost:5000/api/send-whatsapp
# 
# Test request body:
# {
#   "phone": "919876543210",
#   "message": "Hello from Relisant SmartClass!",
#   "studentId": 1,
#   "messageType": "announcement"
# }
